#!/usr/bin/env bash
# Configures Nginx with a custom HTTP response header (X-Served-By)
# shellcheck disable=SC2154

# 1. Update packages and install Nginx if not already installed
sudo apt-get update -y
sudo apt-get install -y nginx

# 2. Add the custom header inside the server block of the default Nginx configuration
# We use the built-in Nginx variable $hostname to dynamically fetch the server's name
sudo sed -i '/server_name _;/a \\\tadd_header X-Served-By $hostname;' /etc/nginx/sites-available/default

# 3. Restart Nginx to apply changes
sudo systemctl restart nginx
