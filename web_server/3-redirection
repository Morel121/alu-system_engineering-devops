#!/usr/bin/env bash
# Configures an Nginx server to redirect /redirect_me permanently (301)

# 1. Update package lists and install Nginx
apt-get update -y
apt-get install -y nginx

# 2. Configure the 301 redirect using sed
# Find the line 'listen 80 default_server;' and append the redirection rule right below it
sed -i '/listen 80 default_server;/a \\trewrite ^/redirect_me/?$ https://www.youtube.com/watch?v=QH2-TGU1wu4 permanent;' /etc/nginx/sites-available/default

# 3. Restart Nginx to apply changes
service nginx restart
